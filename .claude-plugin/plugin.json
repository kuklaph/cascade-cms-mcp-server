{
  "name": "cascade-cms",
  "version": "1.0.3",
  "description": "Cascade CMS MCP server with 34 tools for reading, editing, searching, auditing, publishing, and managing Cascade CMS content.",
  "author": {
    "name": "kuklaph"
  },
  "homepage": "https://github.com/kuklaph/cascade-cms-mcp-server#readme",
  "repository": "https://github.com/kuklaph/cascade-cms-mcp-server",
  "license": "MIT",
  "keywords": ["mcp", "cascade-cms", "cms", "claude-plugin"],
  "mcpServers": {
    "cascade-cms": {
      "command": "npx",
      "args": ["-y", "cascade-cms-mcp-server"],
      "env": {
        "CASCADE_API_KEY": "${CASCADE_API_KEY}",
        "CASCADE_URL": "${CASCADE_URL}"
      }
    }
  }
}
