{
  "name": "cascade-cms-mcp-server",
  "version": "1.1.2",
  "description": "MCP server exposing Cascade CMS API operations to LLMs and agents",
  "author": "kuklaph",
  "license": "MIT",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "cascade-cms",
    "cms",
    "llm-tools"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kuklaph/cascade-cms-mcp-server.git"
  },
  "bugs": {
    "url": "https://github.com/kuklaph/cascade-cms-mcp-server/issues"
  },
  "homepage": "https://github.com/kuklaph/cascade-cms-mcp-server#readme",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "cascade-cms-mcp-server": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun --watch run src/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "version:update": "bun scripts/update-version.ts",
    "smoke:node": "node scripts/smoke-node.mjs",
    "prepublishOnly": "bun test && bun run build && bun run smoke:node"
  },
  "engines": {
    "node": ">=18",
    "bun": ">=1.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cascade-cms-api": "^2.0.2",
    "dotseal": "^1.0.0",
    "zod": "^4.4.3"
  },
  "overrides": {
    "fast-uri": "^3.1.2",
    "hono": "^4.12.18",
    "ip-address": "^10.1.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3"
  }
}
